{
  "type": "Column",
  "class": "page",
  "children": [
    {
      "type": "Div",
      "class": "header-card",
      "children": [
        { "type": "H1", "text": "goui UI 框架演示", "style": { "textColor": "#FFFFFF" } },
        { "type": "P", "text": "基于 Go 的自绘 UI 引擎 · 声明式配置 · Web 风格组件", "style": { "textColor": "#B3D4FF" }, "props": { "fontWeight": "bold" } }
      ]
    },
    {
      "type": "Row",
      "children": [
        {
          "type": "Div",
          "class": "demo-card",
          "style": { "width": 320 },
          "children": [
            { "type": "H3", "text": "用户登录" },
            { "type": "Div", "class": "form-group", "children": [
              { "type": "Label", "text": "用户名" },
              { "type": "Input", "text": "请输入用户名...", "events": { "change": "onUserChange" } }
            ]},
            { "type": "Div", "class": "form-group", "children": [
              { "type": "Label", "text": "密码" },
              { "type": "Input", "text": "请输入密码...", "events": { "change": "onPassChange" } }
            ]},
            { "type": "Checkbox", "text": "记住登录信息", "props": { "checked": false }, "events": { "change": "onRemember" } },
            { "type": "Div", "class": "button-row", "children": [
              { "type": "Button", "text": "登 录", "props": { "color": "#4285F4" }, "events": { "click": "onLogin" } },
              { "type": "Spacer" },
              { "type": "Button", "text": "注 册", "props": { "color": "#34A853" }, "events": { "click": "onRegister" } }
            ]}
          ]
        },
        {
          "type": "Div",
          "class": "demo-card",
          "style": { "width": 320 },
          "children": [
            { "type": "H3", "text": "设置选项" },
            { "type": "Div", "class": "form-group", "children": [
              { "type": "Label", "text": "消息通知" },
              { "type": "Switch", "text": "启用推送通知", "props": { "value": true }, "events": { "change": "onNotify" } }
            ]},
            { "type": "Div", "class": "form-group", "children": [
              { "type": "Label", "text": "音量调节" },
              { "type": "Slider", "props": { "min": 0, "max": 100, "value": 60, "showLabel": true }, "events": { "change": "onVolume" } }
            ]},
            { "type": "Div", "class": "form-group", "children": [
              { "type": "Label", "text": "主题偏好" },
              { "type": "RadioButton", "text": "浅色模式", "props": { "selected": true, "groupName": "theme" }, "events": { "change": "onThemeLight" } },
              { "type": "RadioButton", "text": "深色模式", "props": { "selected": false, "groupName": "theme" }, "events": { "change": "onThemeDark" } }
            ]}
          ]
        }
      ]
    },
    {
      "type": "Div",
      "class": "demo-card",
      "children": [
        { "type": "H3", "text": "进度展示" },
        { "type": "Div", "class": "form-group", "children": [
          { "type": "Label", "text": "任务进度" },
          { "type": "ProgressBar", "props": { "value": 65, "showLabel": true, "height": 20, "color": "#4285F4" } }
        ]},
        { "type": "Div", "class": "form-group", "children": [
          { "type": "Label", "text": "正在处理..." },
          { "type": "ProgressBar", "props": { "indeterminate": true, "height": 8, "color": "#34A853" } }
        ]}
      ]
    },
    {
      "type": "Div",
      "class": "demo-card",
      "children": [
        { "type": "H3", "text": "排版示例" },
        { "type": "H1", "text": "一级标题 Heading 1" },
        { "type": "H2", "text": "二级标题 Heading 2" },
        { "type": "H3", "text": "三级标题 Heading 3" },
        { "type": "H4", "text": "四级标题 Heading 4" },
        { "type": "P", "text": "这是一段普通段落文本，用于展示 goui 的文本排版能力。支持自动换行、自定义颜色和字体大小。" },
        { "type": "Small", "text": "小号说明文字 · 次要信息展示" }
      ]
    },
    {
      "type": "Div",
      "class": "status-bar",
      "children": [
        { "type": "Small", "text": "goui v0.1 · 声明式 UI 框架 · 基于 Go + OpenGL" }
      ]
    }
  ]
}
